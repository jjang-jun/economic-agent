# AI Provider 설정
# AI_PROVIDER: anthropic | openai | groq | ollama | custom
AI_PROVIDER=anthropic
AI_MODEL=claude-haiku-4-5-20251001
# AI_BASE_URL=              # 커스텀 엔드포인트 (선택)

# API Keys (사용하는 제공자의 키만 설정)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# GROQ_API_KEY=your_groq_api_key_here
# AI_API_KEY=               # 범용 키 (위 키보다 우선)

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 공유 뉴스/시장 브리핑 방
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# 포트폴리오/거래/경제적 자유/대화형 Agent 전용 비공개 방
TELEGRAM_SECRET_CHAT_ID=your_private_telegram_chat_id_here
# TELEGRAM_PRIVATE_CHAT_ID=your_private_telegram_chat_id_here
TELEGRAM_WEBHOOK_SECRET=your_telegram_webhook_secret_here

# Agent job endpoint
JOB_SECRET=your_job_secret_here

# 경제지표 API
BOK_API_KEY=your_bok_api_key_here
FRED_API_KEY=your_fred_api_key_here
DART_API_KEY=your_dart_api_key_here

# Supabase 히스토리 저장소
SUPABASE_PROJECT_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_DB_PASSWORD=your_supabase_db_password_here
# SUPABASE_DB_URL=postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres
# SUPABASE_DNS_RESOLVER=https

# 로컬/Actions 포트폴리오
# PORTFOLIO_FILE=data/portfolio.json
PORTFOLIO_JSON_BASE64=

# 한국투자증권 Open API
KIS_APP_KEY=your_kis_app_key_here
KIS_APP_SECRET=your_kis_app_secret_here
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# Alpaca Market Data
ALPACA_API_KEY_ID=your_alpaca_key_id_here
ALPACA_API_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_DATA_FEED=iex

# Financial Modeling Prep
FMP_BASE_URL=https://financialmodelingprep.com/stable/
FMP_API_KEY=your_fmp_api_key_here

# 뉴스 수집 정책
MAX_URGENT_ALERTS_PER_RUN=3
NEWS_COLLECTOR_LOOKBACK_MINUTES=30
NEWS_COLLECTOR_MAX_LOOKBACK_MINUTES=240
NEWS_COLLECTOR_LOOKBACK_BUFFER_MINUTES=10
STALE_IMMEDIATE_ALERT_MINUTES=30
