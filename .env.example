# AI Provider 설정
# AI_PROVIDER: anthropic | openai | groq | ollama | custom
AI_PROVIDER=anthropic
AI_MODEL=claude-haiku-4-5-20251001
# AI_BASE_URL=              # 커스텀 엔드포인트 (선택)

# API Keys (사용하는 제공자의 키만 설정)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# GROQ_API_KEY=your_groq_api_key_here
# AI_API_KEY=               # 범용 키 (위 키보다 우선)

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 공유 뉴스/시장 브리핑 방
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# 포트폴리오/거래/경제적 자유/대화형 Agent 전용 비공개 방 (선택)
# TELEGRAM_PRIVATE_CHAT_ID=your_private_telegram_chat_id_here
# TELEGRAM_SECRET_CHAT_ID=your_private_telegram_chat_id_here

# 경제지표 API (선택)
BOK_API_KEY=your_bok_api_key_here
FRED_API_KEY=your_fred_api_key_here
DART_API_KEY=your_dart_api_key_here

# Supabase 히스토리 저장소 (선택)
SUPABASE_PROJECT_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_DB_PASSWORD=your_supabase_db_password_here
# SUPABASE_DB_URL=postgresql://postgres.your-project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres
# SUPABASE_DNS_RESOLVER=https

# 로컬 포트폴리오 파일 (선택, 커밋 금지)
# PORTFOLIO_FILE=data/portfolio.json
