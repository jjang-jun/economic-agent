{
  "name": "economic-agent",
  "version": "2.0.0",
  "description": "경제 뉴스 자동 수집 · AI 분석 · Telegram 알림 에이전트",
  "main": "src/check-news.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node --env-file=.env src/check-news.js",
    "digest": "node --env-file=.env src/digest.js",
    "report": "node --env-file=.env src/stock-report.js",
    "evaluate": "node --env-file=.env src/evaluate-recommendations.js",
    "recommendations:list": "node --env-file=.env scripts/list-recommendations.js",
    "trade:record": "node --env-file=.env scripts/record-trade.js",
    "trade:performance": "node --env-file=.env scripts/trade-performance.js",
    "action:report": "node --env-file=.env scripts/action-report.js",
    "review:weekly": "node --env-file=.env scripts/performance-review.js weekly",
    "review:monthly": "node --env-file=.env scripts/performance-review.js monthly",
    "dashboard": "node scripts/dashboard.js",
    "freedom:report": "node --env-file=.env scripts/freedom-report.js",
    "portfolio:snapshot": "node --env-file=.env scripts/portfolio-snapshot.js",
    "portfolio:sync-secret": "bash scripts/sync-portfolio-secret.sh",
    "db:push": "node --env-file=.env scripts/push-supabase.js",
    "db:pull": "node --env-file=.env scripts/pull-supabase.js",
    "db:import-local": "node --env-file=.env scripts/import-local-history.js",
    "test": "node --test"
  },
  "keywords": [
    "economic",
    "news",
    "agent",
    "telegram",
    "ai",
    "rss"
  ],
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "rss-parser": "^3.13.0"
  }
}
